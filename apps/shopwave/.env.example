# Notifyflow Backend API Endpoint URL
NOTIFYFLOW_API_URL=https://notifyflow-api.onrender.com

# Tenant API Key copied from the Notifyflow dashboard
NOTIFYFLOW_API_KEY=YOUR NOTIFYFLOW API KEY
# Target email to send test notifications to (e.g. your personal email for testing)
DEMO_EMAIL=demo@shopwave.com

# Target webhook endpoint URL (e.g. from webhook.site) to inspect webhook delivery payloads
DEMO_WEBHOOK_URL=https://webhook.site/xxxx


