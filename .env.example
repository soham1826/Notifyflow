# API Configuration
PORT=5001
JWT_SECRET=your_super_secret_jwt_key_here
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000


# Database Configuration
# You can use a Supabase PostgreSQL database connection string here.
# Make sure to use the "Direct connection" string (port 5432) for migrations to run successfully.
# Format: postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Redis Configuration (For BullMQ & Rate Limiting)
# format: redis://HOST:PORT
REDIS_URL=redis://localhost:6379

# Email Channel Configuration
RESEND_API_KEY=re_your_resend_api_key_here

# Webhook Channel Configuration
WEBHOOK_SECRET=your_webhook_signing_secret_here

# Provider API Key Encryption Configuration (32 bytes as 64 hex characters)
# WARNING: Changing this key after database keys are stored makes them unrecoverable!
# Generate using: npx tsx scripts/generate-encryption-key.ts
PROVIDER_ENCRYPTION_KEY=

# Supabase Configuration
SUPABASE_URL=https://knjjylrhoogxmorvptgf.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://knjjylrhoogxmorvptgf.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# No JWT secret needed — Supabase uses asymmetric ECC P-256 
# signing. Public key is fetched automatically from the 
# JWKS endpoint at startup using SUPABASE_URL.

